{
    "version": 7,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "toolchainFile": "${sourceDir}/build/${presetName}/conan_toolchain.cmake"
        },
        {
            "name": "gcc-debug",
            "displayName": "GCC Debug (ASan + UBSan)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "JAQL_BUILD_TESTS": "ON",
                "JAQL_BUILD_BENCHMARKS": "OFF",
                "JAQL_ENABLE_ASAN": "ON",
                "JAQL_ENABLE_UBSAN": "ON"
            }
        },
        {
            "name": "gcc-release",
            "displayName": "GCC Release",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "JAQL_BUILD_TESTS": "ON",
                "JAQL_BUILD_BENCHMARKS": "OFF"
            }
        },
        {
            "name": "clang-debug",
            "displayName": "Clang Debug (ASan + UBSan)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "JAQL_BUILD_TESTS": "ON",
                "JAQL_BUILD_BENCHMARKS": "OFF",
                "JAQL_ENABLE_ASAN": "ON",
                "JAQL_ENABLE_UBSAN": "ON"
            }
        },
        {
            "name": "clang-release",
            "displayName": "Clang Release",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "JAQL_BUILD_TESTS": "ON",
                "JAQL_BUILD_BENCHMARKS": "OFF"
            }
        },
        {
            "name": "ci-gcc-debug",
            "displayName": "CI GCC Debug (coverage + Werror)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "JAQL_BUILD_TESTS": "ON",
                "JAQL_BUILD_BENCHMARKS": "OFF",
                "JAQL_ENABLE_COVERAGE": "ON",
                "JAQL_WARNINGS_AS_ERRORS": "ON"
            }
        },
        {
            "name": "ci-clang-debug",
            "displayName": "CI Clang Debug (Werror)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "JAQL_BUILD_TESTS": "ON",
                "JAQL_BUILD_BENCHMARKS": "OFF",
                "JAQL_WARNINGS_AS_ERRORS": "ON"
            }
        },
        {
            "name": "ci-gcc-release",
            "displayName": "CI GCC Release (Werror)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "JAQL_BUILD_TESTS": "ON",
                "JAQL_BUILD_BENCHMARKS": "OFF",
                "JAQL_WARNINGS_AS_ERRORS": "ON"
            }
        },
        {
            "name": "ci-clang-release",
            "displayName": "CI Clang Release (Werror)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "JAQL_BUILD_TESTS": "ON",
                "JAQL_BUILD_BENCHMARKS": "OFF",
                "JAQL_WARNINGS_AS_ERRORS": "ON"
            }
        },
        {
            "name": "asan",
            "displayName": "AddressSanitizer",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "JAQL_BUILD_TESTS": "ON",
                "JAQL_ENABLE_ASAN": "ON"
            }
        },
        {
            "name": "ubsan",
            "displayName": "UndefinedBehaviorSanitizer",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "JAQL_BUILD_TESTS": "ON",
                "JAQL_ENABLE_UBSAN": "ON"
            }
        },
        {
            "name": "tsan",
            "displayName": "ThreadSanitizer",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "JAQL_BUILD_TESTS": "ON",
                "JAQL_ENABLE_TSAN": "ON"
            }
        },
        {
            "name": "benchmark",
            "displayName": "Benchmark (Release + LTO)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "JAQL_BUILD_TESTS": "OFF",
                "JAQL_BUILD_BENCHMARKS": "ON",
                "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "gcc-debug",
            "configurePreset": "gcc-debug"
        },
        {
            "name": "gcc-release",
            "configurePreset": "gcc-release"
        },
        {
            "name": "clang-debug",
            "configurePreset": "clang-debug"
        },
        {
            "name": "clang-release",
            "configurePreset": "clang-release"
        },
        {
            "name": "ci-gcc-debug",
            "configurePreset": "ci-gcc-debug"
        },
        {
            "name": "ci-clang-debug",
            "configurePreset": "ci-clang-debug"
        },
        {
            "name": "ci-gcc-release",
            "configurePreset": "ci-gcc-release"
        },
        {
            "name": "ci-clang-release",
            "configurePreset": "ci-clang-release"
        },
        {
            "name": "asan",
            "configurePreset": "asan"
        },
        {
            "name": "ubsan",
            "configurePreset": "ubsan"
        },
        {
            "name": "tsan",
            "configurePreset": "tsan"
        },
        {
            "name": "benchmark",
            "configurePreset": "benchmark"
        }
    ],
    "testPresets": [
        {
            "name": "gcc-debug",
            "configurePreset": "gcc-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "gcc-release",
            "configurePreset": "gcc-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "clang-debug",
            "configurePreset": "clang-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "clang-release",
            "configurePreset": "clang-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "ci-gcc-debug",
            "configurePreset": "ci-gcc-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "ci-clang-debug",
            "configurePreset": "ci-clang-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "ci-gcc-release",
            "configurePreset": "ci-gcc-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "ci-clang-release",
            "configurePreset": "ci-clang-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "asan",
            "configurePreset": "asan",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "ubsan",
            "configurePreset": "ubsan",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "tsan",
            "configurePreset": "tsan",
            "output": {
                "outputOnFailure": true
            }
        }
    ],
    "workflowPresets": [
        {
            "name": "gcc-debug",
            "steps": [
                {
                    "type": "configure",
                    "name": "gcc-debug"
                },
                {
                    "type": "build",
                    "name": "gcc-debug"
                },
                {
                    "type": "test",
                    "name": "gcc-debug"
                }
            ]
        }
    ]
}
