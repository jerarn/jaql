{
    // clangd language server — point at the default preset build directory.
    // `scripts/bootstrap.sh` and `cmake --preset gcc-debug` configure that tree,
    // and compile_commands.json is written there once CMake has translation units
    // to emit into the compilation database.
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}/build/gcc-debug",
        "--clang-tidy",
        "--header-insertion=never",
        "--completion-style=detailed",
        "--background-index"
    ],
    // Ensure the C/C++ IntelliSense engine defers to clangd (if ms-vscode.cpptools
    // is also installed, disable its IntelliSense to avoid conflicts).
    "C_Cpp.intelliSenseEngine": "disabled",
    // Keep the editor on the repository's preset-driven build layout.
    "cmake.useCMakePresets": "always",
    // Bootstrap/configure tasks install Conan dependencies before configuring.
    "cmake.configureOnOpen": false,
    // Associate .hpp files with C++ so language features activate correctly.
    "files.associations": {
        "*.hpp": "cpp",
        "*.cpp": "cpp"
    },
    // Format on save using the repo's .clang-format (Google style, column 100).
    "editor.formatOnSave": true,
    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },
    // Trim trailing whitespace and ensure a final newline — consistent with
    // clang-format's output.
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    // // Exclude build and Conan cache artifacts from the file explorer and search.
    // "files.exclude": {
    //     "**/build/**": true,
    //     "**/.conan2/**": true
    // },
    "search.exclude": {
        "**/build/**": true,
        "**/.conan2/**": true
    },
    // Conan is installed via pip; a project .venv is optional (see docs/dev/setup.md).
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.terminal.activateEnvironment": true,
    "python-envs.defaultEnvManager": "ms-python.python:venv",
    // Prepend .venv/bin so integrated terminals and tasks find Conan when using a venv.
    "terminal.integrated.env.linux": {
        "PATH": "${workspaceFolder}/.venv/bin:${env:PATH}"
    }
}
