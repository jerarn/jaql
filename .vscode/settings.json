{
    // clangd language server — point at the build directory that contains
    // compile_commands.json (generated by cmake --preset jaql-debug).
    // The symlink at the repo root (ln -sf build/jaql-debug/compile_commands.json)
    // is the simplest option; the fallback array tries common build directories.
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}",
        "--clang-tidy",
        "--header-insertion=never",
        "--completion-style=detailed",
        "--background-index"
    ],
    // Ensure the C/C++ IntelliSense engine defers to clangd (if ms-vscode.cpptools
    // is also installed, disable its IntelliSense to avoid conflicts).
    "C_Cpp.intelliSenseEngine": "disabled",
    // Associate .hpp files with C++ so language features activate correctly.
    "files.associations": {
        "*.hpp": "cpp",
        "*.cpp": "cpp"
    },
    // Format on save using the repo's .clang-format (Google style, column 100).
    "editor.formatOnSave": true,
    "[cpp]": {
        // "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
        "editor.defaultFormatter": "ms-vscode.cpp-devtools"
    },
    // Trim trailing whitespace and ensure a final newline — consistent with
    // clang-format's output.
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    // Exclude build and Conan cache artifacts from the file explorer and search.
    "files.exclude": {
        "**/build/**": true,
        "**/.conan2/**": true
    },
    "search.exclude": {
        "**/build/**": true,
        "**/.conan2/**": true
    },
    "python-envs.defaultEnvManager": "ms-python.python:pyenv"
}
